@model GorevTakipSistemi.Models.Gorev

@{
    ViewData["Title"] = "Görev Detay";
}

<div class="max-w-2xl mx-auto mt-10 px-4">
    
    <div class="antigravity-card overflow-hidden">
        
        <div class="bg-gradient-to-r from-purple-500 to-indigo-600 text-white p-4 flex items-center justify-between">
            <div class="flex items-center gap-2 font-semibold">
                <a asp-action="Index" class="text-white hover:text-indigo-100 no-underline"><i class="bi bi-chevron-left"></i> Görev Detay</a>
            </div>
            <a asp-action="Index" class="text-white font-bold hover:text-indigo-100 no-underline text-lg"><i class="bi bi-x-lg"></i></a>
        </div>

        <div class="p-6">
            <div class="space-y-4 text-[15px]">
                
                <div class="flex border-b border-slate-100 pb-3">
                    <div class="w-1/3 font-semibold text-slate-600">Görev:</div>
                    <div class="w-2/3 text-slate-800 font-medium">@Model.GorevAdi</div>
                </div>

                <div class="flex border-b border-slate-100 pb-3">
                    <div class="w-1/3 font-semibold text-slate-600">Açıklama:</div>
                    <div class="w-2/3 text-slate-800 whitespace-pre-wrap">@(string.IsNullOrEmpty(Model.Aciklama) ? "-" : Model.Aciklama)</div>
                </div>

                <div class="flex border-b border-slate-100 pb-3">
                    <div class="w-1/3 font-semibold text-slate-600">Durum:</div>
                    <div class="w-2/3">
                        @if(Model.DurumAktifMi) {
                            <span class="text-indigo-600 font-bold bg-indigo-50 px-2 py-1 rounded-md">Aktif</span>
                        } else {
                            <span class="text-emerald-600 font-bold bg-emerald-50 px-2 py-1 rounded-md">Tamamlandı</span>
                        }
                    </div>
                </div>

                <div class="flex border-b border-slate-100 pb-3">
                    <div class="w-1/3 font-semibold text-slate-600">Öncelik:</div>
                    <div class="w-2/3">
                        @if(Model.Oncelik == "Yüksek") {
                            <span class="text-red-600 font-bold bg-red-50 px-2 py-1 rounded-md">Yüksek</span>
                        } else if(Model.Oncelik == "Orta") {
                            <span class="text-amber-600 font-bold bg-amber-50 px-2 py-1 rounded-md">Orta</span>
                        } else {
                            <span class="text-emerald-600 font-bold bg-emerald-50 px-2 py-1 rounded-md">Düşük</span>
                        }
                    </div>
                </div>

                <div class="flex pb-2">
                    <div class="w-1/3 font-semibold text-slate-600">Tarih:</div>
                    <div class="w-2/3 text-slate-800">@Model.Tarih.ToString("dd MMMM yyyy")</div>
                </div>
            </div>
        </div>

        <div class="p-4 bg-slate-50 border-t border-slate-100 flex flex-col sm:flex-row justify-end gap-3">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="antigravity-btn font-medium py-3 px-6 no-underline w-full sm:w-auto text-center">
                Görevi Düzenle
            </a>
            
            <a asp-action="Delete" asp-route-id="@Model.Id" onclick="return confirm('Bu görevi silmek istediğinize emin misiniz?');" class="bg-white hover:bg-slate-50 shadow-md hover:shadow-lg rounded-full px-5 py-3 transition-all hover:-translate-y-1 text-red-600 font-medium no-underline w-full sm:w-auto text-center border border-red-200">
                Görevi Sil
            </a>
        </div>
        
    </div>
</div>