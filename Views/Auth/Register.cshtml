@{
    Layout = null; 
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kayıt Ol - GorevTakip</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'] },
                    colors: {
                        indigo: { 50: '#f0f5fa', 100: '#e1ebf5', 500: '#3B8AC4', 600: '#345DA7' },
                        purple: { 500: '#4BB4DE' },
                        slate: { 50: '#faf6f3' }
                    }
                }
            }
        }
    </script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://www.google.com/recaptcha/api.js" async defer></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        body { font-family: 'Inter', sans-serif; }
        .swal-text-left { text-align: left !important; font-size: 14px !important; line-height: 1.6 !important; }
    </style>
</head>
<body class="bg-slate-50 flex items-center justify-center min-h-screen p-4 text-slate-800 relative z-0">
    <!-- Floating background decorative blobs - Ocean Palette -->
    <div class="fixed top-[-10%] left-[-10%] w-[40rem] h-[40rem] bg-[#4BB4DE]/40 rounded-full mix-blend-multiply filter blur-[100px] opacity-80 animate-blob pointer-events-none -z-10"></div>
    <div class="fixed top-[-10%] right-[-10%] w-[40rem] h-[40rem] bg-[#3B8AC4]/40 rounded-full mix-blend-multiply filter blur-[100px] opacity-80 animate-blob pointer-events-none -z-10" style="animation-delay: 2s;"></div>
    <div class="fixed bottom-[-10%] left-[20%] w-[40rem] h-[40rem] bg-[#345DA7]/40 rounded-full mix-blend-multiply filter blur-[100px] opacity-80 animate-blob pointer-events-none -z-10" style="animation-delay: 4s;"></div>

    <div class="max-w-md w-full antigravity-card p-8 sm:p-10 animate-fade-in-up">
        <div class="text-center mb-8">
            <h1 class="text-4xl font-black tracking-tight bg-clip-text text-transparent bg-gradient-to-r from-slate-800 to-[#345DA7] mb-2">
                GorevLab.
            </h1>
            <h2 class="text-3xl font-black text-slate-800 tracking-tight mt-4">Yeni Hesap Oluştur</h2>
            <p class="text-slate-600 font-medium mt-2 mb-4">Görevlerinizi yönetmeye hemen başlayın.</p>
            
            @if (GorevTakipSistemi.Models.SiteSettings.BakimModuAktif)
            {
                <div class="bg-red-50 border border-red-200 text-red-600 rounded-lg p-3 text-sm font-semibold mb-4 shadow-sm animate-pulse">
                    ⚠️ Sistem şu an bakım modundadır. Kayıt işlemleri geçici olarak durdurulmuştur.
                </div>
            }
        </div>

        <form asp-controller="Auth" asp-action="Register" method="post" class="space-y-4">
            
            @Html.AntiForgeryToken()

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1 px-1">Ad</label>
                    <input type="text" name="Ad" required class="antigravity-input w-full py-3 text-sm" placeholder="Adınız">
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1 px-1">Soyad</label>
                    <input type="text" name="Soyad" required class="antigravity-input w-full py-3 text-sm" placeholder="Soyadınız">
                </div>
            </div>

            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1 px-1">Kullanıcı Adı</label>
                <input type="text" name="KullaniciAdi" required pattern="^[a-zA-Z0-9_]{3,20}$" title="Sadece harf, rakam ve alt çizgi." class="antigravity-input w-full py-3 text-indigo-600 font-semibold text-sm" placeholder="kullanici_adi">
            </div>

            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1 px-1">E-Posta</label>
                <input type="email" name="Email" required class="antigravity-input w-full py-3 text-sm" placeholder="ornek@mail.com">
            </div>

            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1 px-1">Şifre</label>
                <input type="password" name="Sifre" required class="antigravity-input w-full py-3 text-sm" placeholder="••••••••">
            </div>

            <div class="flex items-start pt-2 mb-2">
                <div class="flex items-center h-5 mt-0.5">
                    <input id="kvkk" name="KvkkOnay" type="checkbox" value="true" class="w-4 h-4 border border-slate-300 rounded bg-white focus:ring-2 focus:ring-indigo-500 accent-indigo-600 cursor-pointer" required>
                </div>
                <div class="ml-3 text-xs">
                    <label for="kvkk" class="font-medium text-slate-600 cursor-pointer">
                        Sisteme kayıt olarak <a href="#" onclick="showKVKK(); return false;" class="text-indigo-600 hover:underline font-bold">KVKK Aydınlatma Metni</a>'ni ve <a href="#" onclick="showGizlilik(); return false;" class="text-indigo-600 hover:underline font-bold">Gizlilik Sözleşmesi</a>'ni okuduğumu, anladığımı ve kabul ettiğimi beyan ederim.
                    </label>
                </div>
            </div>

            <div class="flex justify-center my-4">
                <div class="g-recaptcha" data-sitekey="6Ld5eeksAAAAAL0OXk8aPe2Ku94e5IW3flGTRDSo"></div>
            </div>

            <button type="submit" class="antigravity-btn w-full py-3 flex justify-center items-center font-extrabold mt-2">
                Kayıt Ol ve Başla <i class="bi bi-arrow-right ms-2"></i>
            </button>
        </form>

        <div class="mt-8 text-center border-t border-slate-200 pt-6">
            <p class="text-slate-600 text-sm">Zaten bir hesabınız var mı?</p>
            <a asp-action="Login" class="text-indigo-600 font-bold hover:text-indigo-500 transition-colors">Giriş Yap</a>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function() {
            @if (TempData["Error"] != null) {
                @:Swal.fire({ icon: 'error', title: 'Hata!', text: '@Html.Raw(TempData["Error"])', confirmButtonColor: '#4f46e5', background: '#ffffff', color: '#1e293b', borderRadius: '1.5rem', customClass: { popup: 'border border-slate-100 shadow-xl' } });
            }
        });

        function showKVKK() {
            Swal.fire({
                title: 'KVKK Aydınlatma Metni',
                html: `
                    <div class="swal-text-left text-slate-600 space-y-3">
                        <p><strong>1. Veri Sorumlusu</strong><br>
                        Kişisel verileriniz, veri sorumlusu sıfatıyla Emre Çevik (GorevTakip Sistemi) tarafından 6698 sayılı Kişisel Verilerin Korunması Kanunu ("KVKK") kapsamında işlenmektedir.</p>
                        <p><strong>2. İşlenen Kişisel Verileriniz ve İşlenme Amaçları</strong><br>
                        Kimlik verileriniz (Ad, Soyad, Kullanıcı Adı) ve İletişim verileriniz (E-posta), sistemde profil oluşturulması, görev yönetiminin sağlanması ve güvenliğinizin tesisi amacıyla işlenmektedir.</p>
                        <p><strong>3. İşlemenin Hukuki Sebebi</strong><br>
                        Verileriniz, KVKK Madde 5/2(c) "Bir sözleşmenin kurulması veya ifasıyla doğrudan doğruya ilgili olması" ve açık rızanız hukuki sebeplerine dayanarak otomatik yollarla toplanmaktadır.</p>
                        <p><strong>4. Haklarınız</strong><br>
                        KVKK Madde 11 uyarınca; verilerinizin işlenip işlenmediğini öğrenme, amacına uygun kullanılıp kullanılmadığını bilme, düzeltilmesini veya silinmesini talep etme haklarına sahipsiniz.</p>
                    </div>
                `,
                width: '600px',
                confirmButtonText: 'Anladım, Kapat',
                confirmButtonColor: '#4f46e5',
                background: '#ffffff',
                color: '#1e293b',
                padding: '2em',
                customClass: { popup: 'rounded-3xl border border-slate-100 shadow-xl' }
            });
        }

        function showGizlilik() {
            Swal.fire({
                title: 'Gizlilik Sözleşmesi',
                html: `
                    <div class="swal-text-left text-slate-600 space-y-3">
                        <p>Bu platforma kayıt olduğunuzda, sisteme girdiğiniz görevlerin ve log kayıtlarının veritabanımızda güvenli bir şekilde şifrelenerek tutulduğunu kabul edersiniz.</p>
                        <p>Şifreniz sistemimizde geri döndürülemeyecek şekilde (Hash formatında) saklanmaktadır. Sistem yöneticileri dahi şifrenizi göremez.</p>
                        <p>Platformumuz, hesap güvenliğini sağlamak amacıyla giriş yapılan IP adreslerini geçici süreliğine log sisteminde kayıt altına almaktadır.</p>
                        <p>Verileriniz hiçbir şekilde üçüncü şahıs şirketler, reklam ajansları veya kurumlarla paylaşılmayacaktır.</p>
                    </div>
                `,
                width: '600px',
                confirmButtonText: 'Okudum, Kapat',
                confirmButtonColor: '#4f46e5',
                background: '#ffffff',
                color: '#1e293b',
                padding: '2em',
                customClass: { popup: 'rounded-3xl border border-slate-100 shadow-xl' }
            });
        }
    </script>
</body>
</html>