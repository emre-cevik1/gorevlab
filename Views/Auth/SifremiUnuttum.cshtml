@{
    ViewData["Title"] = "Şifremi Unuttum";
    Layout = "_Layout"; 
}

<div class="flex min-h-[80vh] items-center justify-center px-4 py-12 sm:px-6 lg:px-8">
    <div class="w-full max-w-md space-y-8 antigravity-card p-8 sm:p-10 animate-fade-in-up">
        
        <div class="text-center">
            <div class="mx-auto h-16 w-16 rounded-2xl flex items-center justify-center mb-4 bg-gradient-to-r from-purple-500 to-indigo-600 shadow-lg shadow-indigo-500/30">
                <i class="bi bi-key-fill text-white text-3xl"></i>
            </div>
            <h2 class="text-3xl font-extrabold tracking-tight text-slate-800">Şifremi Unuttum</h2>
            <p class="mt-2 text-sm text-slate-600">Endişelenmeyin, e-posta adresinizi girin size bir sıfırlama linki gönderelim.</p>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="bg-red-50 text-red-600 p-4 rounded-2xl text-sm font-bold border border-red-100 text-center">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            </div>
        }

        <form class="mt-8 space-y-6" asp-action="SifremiUnuttum" method="post">
            <div>
                <label class="block text-sm font-bold text-slate-700 mb-1">Kayıtlı E-Posta Adresiniz</label>
                <input name="Email" type="email" required class="antigravity-input w-full py-3 text-sm placeholder:text-slate-400" placeholder="ornek@mail.com">
            </div>

            <div>
                <button type="submit" class="antigravity-btn w-full py-3 text-sm font-semibold flex justify-center">
                    Şifremi Sıfırla
                </button>
            </div>
        </form>

        <div class="text-center mt-4">
            <p class="text-sm text-slate-600">
                Şifrenizi hatırladınız mı? <a asp-action="Login" class="font-semibold text-indigo-600 hover:text-indigo-500">Giriş Yap</a>
            </p>
        </div>

    </div>
</div>