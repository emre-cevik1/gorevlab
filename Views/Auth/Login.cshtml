@{
    Layout = "_Layout"; 
    ViewData["Title"] = "Giriş Yap";
}

<div class="flex min-h-[80vh] items-center justify-center px-4 py-12 sm:px-6 lg:px-8 animate-fade-in-up">
    <div class="w-full max-w-md space-y-8 antigravity-card p-8 sm:p-10" id="login-box" style="display:none;">
        
        <div class="text-center">
            <h1 class="text-4xl font-black tracking-tight bg-clip-text text-transparent bg-gradient-to-r from-slate-800 to-[#345DA7] mb-2">
                GorevLab.
            </h1>
            
            <h2 class="text-xl font-bold tracking-tight text-slate-800">Tekrar Hoş Geldiniz!</h2>
            <p class="mt-1 text-sm text-slate-600 mb-2">Lütfen hesabınıza giriş yapın</p>
            
            @if (GorevTakipSistemi.Models.SiteSettings.BakimModuAktif)
            {
                <div class="bg-red-50 border border-red-200 text-red-600 rounded-lg p-3 text-sm font-semibold mb-4 shadow-sm animate-pulse">
                    ⚠️ Sistem şu an bakım modundadır. Sadece kurucu girişi açıktır.
                </div>
            }
        </div>
        
        @if (ViewBag.HizliGirisUser != null)
        {
            var hizliUser = (GorevTakipSistemi.Models.Kullanici)ViewBag.HizliGirisUser;
            var kelimeler = (hizliUser.Ad + " " + hizliUser.Soyad).Split(' ', StringSplitOptions.RemoveEmptyEntries);
            var basHarfler = kelimeler.Length >= 2 ? kelimeler[0].Substring(0, 1).ToUpper() + kelimeler[kelimeler.Length - 1].Substring(0, 1).ToUpper() : kelimeler[0].Substring(0, 1).ToUpper();

            <div class="bg-slate-50 border border-slate-200 rounded-2xl p-6 text-center shadow-inner mb-6">
                <div class="h-16 w-16 mx-auto rounded-full bg-gradient-to-r from-[#3B8AC4] to-[#345DA7] text-white flex items-center justify-center font-bold text-xl shadow-lg mb-4">
                    @basHarfler
                </div>
                <h3 class="text-lg font-bold text-slate-800">@hizliUser.Ad @hizliUser.Soyad</h3>
                <p class="text-sm text-slate-500 mb-6">@@@hizliUser.KullaniciAdi</p>
                
                <form asp-action="LoginHizli" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="w-full py-3 px-4 bg-gradient-to-r from-[#3B8AC4] to-[#345DA7] text-white font-bold rounded-xl shadow-lg hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300">
                        Devam Et
                    </button>
                </form>
                
                <div class="mt-4">
                    <button onclick="document.cookie='GorevLabRememberToken=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;'; window.location.reload();" class="text-sm font-semibold text-slate-500 hover:text-slate-700 transition-colors">
                        Farklı bir hesapla giriş yap
                    </button>
                </div>
            </div>
        }
        else
        {
            <form class="mt-8 space-y-6" asp-action="Login" method="post">
            
            @Html.AntiForgeryToken()
            
            <div class="rounded-md space-y-4">
                <div class="mb-4">
                    <label class="form-label font-bold text-slate-700 block mb-1">Kullanıcı Adı</label>
                    <input id="kullaniciAdiInput" name="kullaniciAdi" type="text" required class="antigravity-input w-full py-3 text-slate-800 placeholder-slate-400" placeholder="Kullanıcı adınızı girin">
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-1">Şifre</label>
                    <input id="sifreInput" name="Sifre" type="password" required class="antigravity-input w-full py-3 text-slate-800 placeholder-slate-400" placeholder="••••••••">
                </div>
            </div>

            <div class="flex items-center mt-2 mb-4">
                <input type="checkbox" id="BeniHatirla" name="BeniHatirla" value="true" class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded" checked>
                <label for="BeniHatirla" class="ml-2 block text-sm text-slate-700 font-semibold cursor-pointer">
                    Beni 10 Gün Boyunca Hatırla
                </label>
            </div>

            <div class="flex justify-between items-center mt-2 mb-4">
                <a href="javascript:void(0)" onclick="kullaniciAdiSor()" class="text-sm font-semibold text-indigo-600 hover:text-indigo-500 transition-colors">
                    Kullanıcı Adımı Unuttum
                </a>
                <a asp-action="SifremiUnuttum" class="text-sm font-semibold text-indigo-600 hover:text-indigo-500 transition-colors">
                    Şifremi Unuttum
                </a>
            </div>

            <div>
                <button type="submit" class="antigravity-btn w-full py-3 flex justify-center text-sm font-bold">
                    Sisteme Giriş Yap
                </button>
            </div>
        </form>
        }

        <div class="text-center mt-4">
            <p class="text-sm text-slate-600">
                Hesabın yok mu? <a asp-action="Register" class="font-semibold text-indigo-600 hover:text-indigo-500">Hemen Kayıt Ol</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#login-box').fadeIn(1000).css({ 'margin-top': '20px' }).animate({ 'margin-top': '0px' }, 800);
        });

        function kullaniciAdiSor() {
            Swal.fire({
                title: 'Kullanıcı Adımı Unuttum',
                text: 'Sisteme kayıtlı e-posta adresinizi girin:',
                input: 'email',
                inputPlaceholder: 'ornek@mail.com',
                showCancelButton: true,
                confirmButtonText: 'Bul ve Gönder',
                cancelButtonText: 'İptal',
                confirmButtonColor: '#4f46e5',
                cancelButtonColor: '#94a3b8',
                background: '#ffffff',
                color: '#1e293b',
                borderRadius: '1.5rem',
                customClass: {
                    popup: 'border border-slate-100 shadow-xl',
                    input: 'bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 px-4 py-3 text-slate-800'
                }
            }).then((result) => {
                if (result.isConfirmed && result.value) {
                    window.location.href = `/Auth/KullaniciAdiHatirlat?email=${result.value}`;
                }
            });
        }
    </script>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var kullaniciAdiInput = document.getElementById('kullaniciAdiInput');
            var sifreInput = document.getElementById('sifreInput');
            
            if (kullaniciAdiInput && kullaniciAdiInput.value.trim() !== '') {
                sifreInput.focus(); // Eğer kullanıcı adı doluysa direkt şifreye odaklan
            } else if (kullaniciAdiInput) {
                kullaniciAdiInput.focus();
            }
        });
    </script>
}