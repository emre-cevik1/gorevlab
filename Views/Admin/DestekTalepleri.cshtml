@model List<GorevTakipSistemi.Models.DestekMesaji>
@{
    ViewData["Title"] = "Destek Talepleri";
}

<div class="container mt-4 max-w-7xl mx-auto mb-12">
    <div class="flex flex-col md:flex-row md:items-center justify-between mb-8 gap-4 antigravity-card p-6">
        <div>
            <h2 class="text-3xl md:text-4xl font-black text-slate-800 tracking-tight flex items-center gap-3">
                <i class="bi bi-envelope-paper text-indigo-600"></i> Destek Talepleri
            </h2>
            <p class="text-slate-500 font-medium mt-1">Kullanıcılardan gelen sorular, sorunlar ve bildirimler.</p>
        </div>
        
        <div class="relative w-full md:w-80">
            <input type="text" id="destekAra" class="antigravity-input w-full pl-10 pr-4 py-3 text-sm font-medium" placeholder="Kullanıcı veya konu ara...">
            <i class="bi bi-search absolute left-4 top-3.5 text-slate-500"></i>
        </div>
    </div>

    <div class="antigravity-card overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 w-full text-left">
                <thead class="bg-slate-50 border-b border-slate-200">
                    <tr>
                        <th class="px-6 py-5 text-xs font-black text-slate-500 uppercase tracking-widest border-0">Kullanıcı</th>
                        <th class="px-6 py-5 text-xs font-black text-slate-500 uppercase tracking-widest border-0">Konu & Mesaj</th>
                        <th class="px-6 py-5 text-center text-xs font-black text-slate-500 uppercase tracking-widest border-0">Durum</th>
                        <th class="px-6 py-5 text-end text-xs font-black text-slate-500 uppercase tracking-widest border-0">İşlem</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-[#e2e8f0]">
                    @foreach (var talep in Model)
                    {
                        var ad = talep.Kullanici?.Ad;
                        var basHarf = string.IsNullOrEmpty(ad) ? "U" : ad.Substring(0, 1).ToUpper();
                        var adSoyad = (talep.Kullanici?.Ad ?? "Bilinmeyen") + " " + (talep.Kullanici?.Soyad ?? "Kullanıcı");
                        var email = talep.Kullanici?.Email ?? "-";

                        <tr class="transition-all hover:scale-[1.01] hover:shadow-md bg-white rounded-lg admin-destek-satiri group">
                            <td class="px-6 py-4 border-0">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center font-black border border-indigo-200 shrink-0">
                                        @basHarf
                                    </div>
                                    <div class="min-w-0">
                                        <h4 class="font-bold text-slate-800 text-sm mb-0 truncate aranacak-kullanici">@adSoyad</h4>
                                        <p class="text-[11px] text-slate-500 font-medium mb-0 truncate">@email</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 border-0 max-w-xs">
                                <h5 class="text-sm font-bold text-slate-700 mb-1 truncate aranacak-konu">@talep.Konu</h5>
                                <p class="text-xs text-slate-500 truncate mb-1" title="@talep.Mesaj">@talep.Mesaj</p>
                                <small class="text-[10px] text-slate-500 font-bold flex items-center gap-1">
                                    <i class="bi bi-clock-history text-indigo-600"></i> @talep.Tarih.ToString("dd.MM.yyyy HH:mm")
                                </small>
                            </td>
                            <td class="px-6 py-4 text-center border-0">
                                @if (talep.IsCevaplandi)
                                {
                                    <span class="inline-flex items-center gap-1 bg-emerald-50 text-emerald-600 px-3 py-1.5 rounded-lg text-[10px] font-black uppercase border border-emerald-200">
                                        <i class="bi bi-check-circle-fill"></i> Cevaplandı
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1 bg-amber-50 text-amber-600 px-3 py-1.5 rounded-lg text-[10px] font-black uppercase border border-amber-200 animate-pulse">
                                        <i class="bi bi-hourglass-split"></i> Bekliyor
                                    </span>
                                }
                            </td>
                            <td class="px-6 py-4 text-end border-0">
                                <div class="flex items-center justify-end gap-2">
                                    @{ var btnClass = talep.IsCevaplandi ? "bg-slate-100 text-slate-600 hover:bg-slate-200" : "bg-indigo-50 text-indigo-600 hover:bg-indigo-600 hover:text-white"; }
                                    <button type="button" data-bs-toggle="modal" data-bs-target="#cevapModal-@talep.Id" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-xl text-sm font-bold transition-all border-0 cursor-pointer @btnClass">
                                        @if(talep.IsCevaplandi) {
                                            <span><i class="bi bi-eye-fill"></i> İncele</span>
                                        } else {
                                            <span><i class="bi bi-reply-fill"></i> Cevapla</span>
                                        }
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            @if(!Model.Any()) {
                <div class="py-16 text-center text-slate-400 bg-slate-50/50">
                    <i class="bi bi-inbox text-5xl mb-4 block opacity-30"></i>
                    <p class="font-bold text-lg text-slate-500">Sistemde hiç destek talebi bulunmuyor.</p>
                </div>
            }
        </div>
    </div>
</div>

@foreach (var talep in Model)
{
    <div class="modal fade" id="cevapModal-@talep.Id" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow-2xl rounded-3xl overflow-hidden">
                <div class="bg-indigo-600 p-4 flex justify-between items-center text-white">
                    <h5 class="modal-title font-bold flex items-center gap-2 m-0 text-lg">
                        <i class="bi bi-ticket-detailed"></i> Destek Talebi #@talep.Id
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                
                <form action="/Admin/DestekCevapla" method="post">
                    <input type="hidden" name="mesajId" value="@talep.Id" />
                    <div class="modal-body p-6 bg-white">
                        <div class="bg-slate-50 p-4 rounded-2xl border border-slate-200 mb-5 relative">
                            <div class="absolute -top-3 left-4 bg-white px-2 text-xs font-bold text-indigo-600 border border-slate-200 rounded-lg">Kullanıcı Mesajı</div>
                            <h4 class="font-black text-slate-800 text-lg mt-2 mb-2">@talep.Konu</h4>
                            <p class="text-sm text-slate-600 whitespace-pre-wrap mb-0">@talep.Mesaj</p>
                        </div>

                        @if(talep.IsCevaplandi) {
                            <div class="bg-emerald-50 p-4 rounded-2xl border border-emerald-200 relative">
                                <div class="absolute -top-3 left-4 bg-white px-2 text-xs font-bold text-emerald-600 border border-slate-200 rounded-lg">Verilen Cevap</div>
                                <p class="text-sm text-emerald-700 whitespace-pre-wrap mt-2 mb-0">@talep.Cevap</p>
                            </div>
                        } else {
                            <div>
                                <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2 px-1">Yanıtınız</label>
                                <textarea name="cevap" rows="4" required class="antigravity-input w-full px-4 py-3 text-sm resize-none" placeholder="Kullanıcıya iletilecek cevabı yazın (Mail olarak da gidecektir)..."></textarea>
                            </div>
                        }
                    </div>
                    <div class="modal-footer border-t-0 bg-slate-50 p-4 flex justify-end gap-2">
                        
                        @if(talep.IsCevaplandi) {
                           @if(talep.IsCevaplandi) {
    <button type="button" onclick="islemOnayi('/Admin/DestekTalebiSil/@talep.Id', 'sil')" 
            class="inline-flex items-center gap-1.5 bg-red-50 text-red-600 hover:bg-red-600 hover:text-white font-bold py-2 px-5 rounded-xl transition-all text-sm border-0 cursor-pointer">
        <i class="bi bi-trash3-fill"></i> Sil
    </button>
}
                        }

                        <button type="button" class="bg-slate-100 border border-slate-200 text-slate-600 hover:bg-slate-200 font-bold py-2 px-5 rounded-xl transition-colors text-sm border-0 cursor-pointer" data-bs-dismiss="modal">Kapat</button>
                        
                        @if(!talep.IsCevaplandi) {
                            <button type="submit" class="antigravity-btn py-2 px-5 font-bold shadow-lg text-sm cursor-pointer">Cevapla ve Mail At</button>
                        }
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        $(document).ready(function() {
            $("#destekAra").on("keyup", function() {
                var value = $(this).val().toLowerCase();
                $(".admin-destek-satiri").filter(function() {
                    var kullanici = $(this).find(".aranacak-kullanici").text().toLowerCase();
                    var konu = $(this).find(".aranacak-konu").text().toLowerCase();
                    $(this).toggle(kullanici.indexOf(value) > -1 || konu.indexOf(value) > -1);
                });
            });
        });
    </script>
}