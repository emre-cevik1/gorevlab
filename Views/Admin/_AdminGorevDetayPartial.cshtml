@model GorevTakipSistemi.Models.Gorev

<div class="modal-header border-b border-slate-200 bg-white p-5 rounded-t-2xl text-slate-800">
    <h5 class="modal-title font-extrabold text-lg flex items-center gap-2">
        <i class="bi bi-shield-check text-indigo-600"></i> Sistem Görev Denetimi
    </h5>
    <button type="button" class="btn-close text-sm" data-bs-dismiss="modal" aria-label="Kapat"></button>
</div>

<div class="modal-body p-6 bg-white">
    
    <div class="antigravity-card p-4 mb-5 flex items-center gap-4 relative overflow-hidden">
        <div class="absolute right-0 top-0 w-24 h-24 bg-indigo-600 rounded-full -mr-10 -mt-10 opacity-10"></div>
        
        <div class="w-12 h-12 bg-indigo-50 text-indigo-600 rounded-full flex items-center justify-center font-black text-xl z-10 shadow-md border border-indigo-200">
            @(Model.Kullanici?.Ad?.Substring(0,1) ?? "U")
        </div>
        <div class="z-10">
            <h6 class="text-[10px] font-black text-slate-500 uppercase tracking-widest mb-1">Görev Sahibi</h6>
            <p class="font-bold text-slate-800 m-0 text-lg">
                @(Model.Kullanici?.Ad) @(Model.Kullanici?.Soyad) 
                <span class="text-indigo-600 font-semibold text-sm block sm:inline sm:ml-1">(@(Model.Kullanici?.KullaniciAdi))</span>
            </p>
        </div>
    </div>

    <div class="mb-5">
        <small class="text-indigo-500 font-bold uppercase tracking-wider text-[10px]">Görev Başlığı</small>
        <h4 class="text-xl font-black text-slate-800 mb-2 mt-1">@Model.GorevAdi</h4>
    </div>

    @if(!string.IsNullOrEmpty(Model.Aciklama)) {
        <div class="bg-slate-50 p-4 rounded-xl border border-slate-200 mb-4">
            <h6 class="text-[10px] font-black text-slate-500 uppercase tracking-widest mb-2">Açıklama</h6>
            <p class="text-slate-700 text-sm m-0 leading-relaxed whitespace-pre-wrap">@Model.Aciklama</p>
        </div>
    } else {
        <div class="bg-slate-50 p-4 rounded-xl border border-slate-200 mb-4 border-dashed text-center">
            <p class="text-slate-400 text-sm m-0 italic">Kullanıcı bu görev için bir açıklama girmemiş.</p>
        </div>
    }

    <div class="grid grid-cols-2 gap-4">
        <div class="bg-slate-50 p-4 rounded-xl border border-slate-200 text-center">
            <small class="text-slate-500 font-bold uppercase tracking-wider text-[10px] block mb-2">Durum</small>
            @if(!Model.DurumAktifMi) {
                <span class="bg-emerald-50 text-emerald-600 px-3 py-1.5 rounded-lg text-[11px] font-bold inline-flex items-center gap-1 w-full justify-center border border-emerald-200"><i class="bi bi-check-circle-fill"></i> Tamamlandı</span>
            } else if (Model.Tarih.Date < DateTime.Now.Date) {
                <span class="bg-red-50 text-red-600 px-3 py-1.5 rounded-lg text-[11px] font-bold inline-flex items-center gap-1 w-full justify-center border border-red-200"><i class="bi bi-exclamation-circle-fill"></i> Gecikti</span>
            } else {
                <span class="bg-indigo-50 text-indigo-600 px-3 py-1.5 rounded-lg text-[11px] font-bold inline-flex items-center gap-1 w-full justify-center border border-indigo-200"><i class="bi bi-hourglass-split"></i> Bekliyor</span>
            }
        </div>
        <div class="bg-slate-50 p-4 rounded-xl border border-slate-200 text-center">
            <small class="text-slate-500 font-bold uppercase tracking-wider text-[10px] block mb-2">Hedef Tarih</small>
            <span class="text-slate-700 font-bold text-sm flex items-center justify-center gap-1 h-[26px]">
                <i class="bi bi-calendar3 text-indigo-600"></i> @Model.Tarih.ToString("dd MMMM yyyy")
            </span>
        </div>
    </div>
</div>

<div class="modal-footer border-t border-slate-200 p-4 bg-slate-50 rounded-b-2xl flex justify-between items-center">
    <button type="button" onclick="islemOnayi('/Admin/KullaniciGoreviSil/@Model.Id', 'sil')" class="inline-flex items-center gap-1.5 bg-red-500 hover:bg-red-600 text-white font-bold text-sm px-5 py-2.5 rounded-xl transition-colors border-0 cursor-pointer">
        <i class="bi bi-trash3"></i> Sistemden Sil
    </button>
    <button type="button" class="bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold py-2.5 px-6 rounded-xl transition-colors text-sm border border-slate-200 cursor-pointer" data-bs-dismiss="modal">Kapat</button>
</div>