@model GorevTakipSistemi.Models.Ekip
@{
    ViewData["Title"] = "Yeni Ekip Kur";
}

<div class="max-w-2xl mx-auto mt-10 px-4 mb-20">
    <div class="antigravity-card overflow-hidden">
        
        <div class="bg-gradient-to-r from-purple-500 to-indigo-600 p-8 text-center relative overflow-hidden">
            <div class="absolute -right-4 -top-4 opacity-10">
                <i class="bi bi-rocket-takeoff text-9xl text-white"></i>
            </div>
            <div class="relative z-10">
                <div class="w-16 h-16 bg-white/20 rounded-2xl flex items-center justify-center mx-auto mb-4 backdrop-blur-sm border border-white/20 hover:-translate-y-1 transition-all">
                    <i class="bi bi-rocket-takeoff text-3xl text-white"></i>
                </div>
                <h2 class="text-2xl font-black text-white m-0 tracking-wide">Yeni Ekip Kur</h2>
                <p class="text-indigo-100 mt-2 text-sm font-medium">Takım arkadaşlarını topla, görevleri birlikte yönet!</p>
            </div>
        </div>

        <form asp-controller="Ekip" asp-action="Olustur" method="post" class="p-8">
            <div class="mb-5">
                <label class="block text-sm font-bold text-slate-800 mb-2">Ekip Adı <span class="text-red-500">*</span></label>
                <input asp-for="Ad" type="text" class="antigravity-input w-full font-semibold" placeholder="Örn: Ar-Ge Takımı, Bitirme Projesi Grubu vb." required>
            </div>

            <div class="mb-8">
                <label class="block text-sm font-bold text-slate-800 mb-2">Ekip Açıklaması <span class="text-slate-600 font-normal">(İsteğe Bağlı)</span></label>
                <textarea asp-for="Aciklama" rows="3" class="antigravity-input w-full resize-none" placeholder="Bu ekip ne iş yapar? Amacı nedir?"></textarea>
            </div>

            <div class="flex gap-3 pt-2 border-t border-slate-100 mt-6">
                <a href="/Ekip/Index" class="w-1/3 text-center px-4 py-3.5 rounded-2xl border border-slate-200 text-slate-600 font-bold hover:bg-slate-50 hover:text-slate-800 transition-colors no-underline flex justify-center items-center">
                    Vazgeç
                </a>
                <button type="submit" class="w-2/3 antigravity-btn py-3.5 px-4 flex justify-center items-center gap-2">
                    <i class="bi bi-check2-circle text-lg"></i> Ekibi Oluştur
                </button>
            </div>
        </form>
    </div>
</div>