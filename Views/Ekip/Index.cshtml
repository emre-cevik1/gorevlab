@model List<GorevTakipSistemi.Models.Ekip>
@{
    ViewData["Title"] = "Ekiplerim";
    var currentUserId = Context.Session.GetInt32("KullaniciId");
    var gelenDavetler = ViewBag.GelenDavetler as List<GorevTakipSistemi.Models.EkipDavet>;
}

<div class="max-w-7xl mx-auto mt-6 px-4 mb-10">
    
    <div class="mb-8 flex flex-col sm:flex-row justify-between items-center gap-4">
        <div>
            <h1 class="text-2xl sm:text-3xl font-extrabold text-slate-800 tracking-tight">Ekiplerim 🚀</h1>
            <p class="text-slate-600 text-sm mt-1">Takımların ve sana gelen teklifler.</p>
        </div>
        <a href="/Ekip/Olustur" class="antigravity-btn px-6 py-3 no-underline flex items-center gap-2">
            <i class="bi bi-plus-lg text-lg"></i> Yeni Ekip Kur
        </a>
    </div>

    @if (gelenDavetler != null && gelenDavetler.Any())
    {
        <div class="mb-10 animate-pulse-slow">
            <h3 class="text-sm font-bold text-indigo-600 uppercase tracking-widest mb-4 flex items-center gap-2">
                <span class="relative flex h-3 w-3">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-3 w-3 bg-indigo-500"></span>
                </span>
                Sana Yeni Teklifler Var!
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                @foreach (var davet in gelenDavetler)
                {
                    <div id="davet-row-@davet.Id" class="antigravity-card p-5 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 hover:-translate-y-1 transition-all">
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 bg-slate-50 rounded-2xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 flex items-center justify-center text-indigo-600 shrink-0 hover:-translate-y-1 transition-all">
                                <i class="bi bi-envelope-paper-heart text-2xl"></i>
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-800 m-0">@davet.Ekip.Ad</h4>
                                <p class="text-xs text-slate-600 m-0">Gönderen: <b class="text-indigo-600">@@@davet.Gonderen.KullaniciAdi</b></p>
                            </div>
                        </div>
                        <div class="flex gap-2 w-full sm:w-auto mt-2 sm:mt-0">
                            <button onclick="davetIslem(@davet.Id, 'DavetKabul')" class="flex-1 sm:flex-none bg-emerald-50 text-emerald-600 hover:bg-emerald-100 px-4 py-2.5 rounded-lg text-xs font-bold transition-colors">Kabul Et</button>
                            <button onclick="davetIslem(@davet.Id, 'DavetRed')" class="flex-1 sm:flex-none bg-slate-50 hover:bg-slate-100 text-slate-600 border border-slate-200 px-4 py-2.5 rounded-lg text-xs font-bold transition-colors">Reddet</button>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        @if(Model != null && Model.Any()) {
            foreach(var ekip in Model) {
                <div class="antigravity-card p-6 relative overflow-hidden group hover:-translate-y-1 transition-all duration-300">
                    <a href="/Ekip/Detay/@ekip.Id" class="absolute inset-0 z-10 cursor-pointer"></a>
                    <div class="absolute top-0 left-0 w-1.5 h-full bg-gradient-to-b from-purple-500 to-indigo-600 transition-colors"></div>
                    <div class="relative z-0">
                        <h3 class="text-lg font-black text-slate-800 mb-2">@ekip.Ad</h3>
                        <p class="text-sm text-slate-600 mb-5 line-clamp-2 h-10">@(string.IsNullOrEmpty(ekip.Aciklama) ? "Bu ekibin henüz bir açıklaması yok." : ekip.Aciklama)</p>
                        <div class="flex justify-between items-center border-t border-slate-100 pt-4">
                            <span class="text-xs font-bold text-slate-600 bg-slate-50 px-3 py-1.5 rounded-lg border border-slate-200">
                                <i class="bi bi-people-fill mr-1"></i> @(ekip.Uyeler?.Count ?? 1) Üye
                            </span>
                            @if(ekip.KurucuId == currentUserId) {
                                <span class="text-xs font-bold text-emerald-600 bg-emerald-50 px-3 py-1.5 rounded-lg border border-emerald-200">Kurucu</span>
                            } else {
                                <span class="text-xs font-bold text-indigo-600 bg-indigo-50 px-3 py-1.5 rounded-lg border border-indigo-200">Üye</span>
                            }
                        </div>
                    </div>
                </div>
            }
        } else {
            <div class="col-span-full antigravity-card border-2 border-dashed border-slate-200 p-12 text-center">
                <i class="bi bi-diagram-3 text-4xl text-indigo-500 mb-4 block hover:-translate-y-1 transition-all"></i>
                <h3 class="text-xl font-bold text-slate-800">Henüz Bir Ekibin Yok</h3>
                <p class="text-slate-600 text-sm mt-2 mb-6">Hemen yeni bir ekip kur veya davet gelmesini bekle!</p>
                <a href="/Ekip/Olustur" class="text-indigo-600 font-bold hover:underline">Yeni Ekip Kur &rarr;</a>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
    function davetIslem(id, action) {
        console.log("1. Davet İşlemi Başladı! Action:", action, "| Davet ID:", id);

        $.ajax({
            url: '/Ekip/' + action,
            type: 'POST',
            data: { davetId: id },
            success: function (res) {
                console.log("2. Sunucudan Cevap Geldi:", res);
                if(res.success) {
                    Swal.fire({ icon: 'success', title: 'İşlem Başarılı', text: res.message, timer: 1500, showConfirmButton: false })
                    .then(() => { location.reload(); });
                } else {
                    Swal.fire({ icon: 'error', title: 'Hata', text: res.message });
                }
            },
            error: function (xhr, status, error) {
                console.error("🔥 3. İSTEK ÇÖKTÜ!");
                console.error("Durum Kodu:", xhr.status);
                console.error("Hata Detayı:", xhr.responseText);
                alert("Sunucuda kritik bir hata oluştu! Lütfen F12'ye basıp Konsol (Console) sekmesine bak.");
            }
        });
    }
</script>
}