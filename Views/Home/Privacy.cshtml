@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="max-w-3xl mx-auto mt-10 px-4 mb-10">
    <div class="bg-[#242440] rounded-2xl border border-[#2e2e4a] neo-raised p-8 sm:p-10">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-12 h-12 bg-crimson-950 rounded-xl flex items-center justify-center border border-crimson-800/50">
                <i class="bi bi-shield-lock text-2xl text-crimson-400"></i>
            </div>
            <h1 class="text-2xl font-black text-gray-200 m-0">@ViewData["Title"]</h1>
        </div>
        <div class="bg-[#1e1e38] rounded-xl border border-[#2e2e4a] p-6 neo-inset">
            <p class="text-gray-400 m-0">Use this page to detail your site's privacy policy.</p>
        </div>
    </div>
</div>
