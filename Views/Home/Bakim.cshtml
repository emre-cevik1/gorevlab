@{
    ViewData["Title"] = "Sistem Güncelleniyor";
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sistem Güncelleniyor - GorevLab.</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .ocean-gradient {
            background: linear-gradient(135deg, #345DA7 0%, #3B8AC4 50%, #4BB4DE 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .ocean-bg {
            background: linear-gradient(135deg, #345DA7 0%, #3B8AC4 50%, #4BB4DE 100%);
        }
    </style>
</head>
<body>
    <div class="max-w-xl w-full mx-4 bg-white/80 backdrop-blur-xl rounded-3xl shadow-2xl p-8 sm:p-12 text-center border border-white/50">
        <div class="mb-8">
            <h1 class="text-4xl font-extrabold tracking-tight ocean-gradient mb-2">GorevLab.</h1>
        </div>
        
        <div class="w-24 h-24 bg-blue-50 rounded-full flex items-center justify-center mx-auto mb-6 shadow-inner">
            <svg class="w-12 h-12 text-[#3B8AC4]" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
        </div>

        <h2 class="text-3xl font-bold text-slate-800 mb-4">Sistem Güncelleniyor</h2>
        <p class="text-slate-500 mb-8 leading-relaxed">
            Sizlere daha iyi bir deneyim sunabilmek için şu anda altyapımızda planlı bir güncelleme çalışması yapıyoruz. 
            Lütfen kısa bir süre sonra tekrar deneyin.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/Auth/Login" class="ocean-bg text-white px-8 py-3 rounded-xl font-semibold shadow-lg shadow-blue-500/30 hover:shadow-blue-500/50 transform hover:-translate-y-0.5 transition-all duration-200">
                Sistem Kurucusu Girişi
            </a>
        </div>
    </div>
</body>
</html>
