@{
    ViewData["Title"] = "Bize Ulaşın";
}

<div class="max-w-3xl mx-auto mt-10 px-4">
    <div class="antigravity-card overflow-hidden">
        <div class="bg-gradient-to-r from-purple-500 to-indigo-600 p-8 sm:p-10 text-center text-white relative">
            <div class="absolute top-0 right-0 -mr-8 -mt-8 w-32 h-32 rounded-full bg-indigo-400 opacity-5 blur-2xl"></div>
            <div class="inline-flex items-center justify-center w-16 h-16 bg-white/10 rounded-2xl mb-4 shadow-inner border border-white/10">
                <i class="bi bi-headset text-3xl"></i>
            </div>
            <h2 class="text-3xl font-black tracking-tight mb-2">Destek Merkezi</h2>
            <p class="text-indigo-100 font-medium">Sorularınız veya karşılaştığınız problemler için bize yazın.</p>
        </div>

        <div class="p-8 sm:p-10">
            <form asp-controller="Iletisim" asp-action="Gonder" method="post" class="space-y-6">
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2 px-1">Konu</label>
                    <input type="text" name="konu" required class="w-full px-5 py-4 antigravity-input outline-none font-medium" placeholder="Örn: Şifremi sıfırlayamıyorum, Görev hatası vb.">
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2 px-1">Mesajınız</label>
                    <textarea name="mesaj" rows="5" required class="w-full px-5 py-4 antigravity-input outline-none font-medium resize-none" placeholder="Lütfen karşılaştığınız durumu detaylıca açıklayın..."></textarea>
                </div>

                <div class="pt-2">
                    <button type="submit" class="w-full antigravity-btn py-4 flex items-center justify-center gap-2 font-extrabold cursor-pointer">
                        <i class="bi bi-send-fill"></i> Talebi Gönder
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>